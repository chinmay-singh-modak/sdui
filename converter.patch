-// import 'package:flutter_sdui_converter/flutter_sdui_converter.dart';
+import 'package:flutter_sdui_converter/flutter_sdui_converter.dart';
 
-void main() {
-  // var awesome = Awesome();
-  // print('awesome: ${awesome.isAwesome}');
+/// Example: converting a Flutter project to an SDUI JSON schema.
+///
+/// Run this with:
+/// ```bash
+/// dart run example/flutter_sdui_converter_example.dart
+/// ```
+Future<void> main() async {
+  // Convert a Flutter project at the given path.
+  final result = await SduiConverter.convert(
+    projectPath: '.',
+    config: const SduiConfig(
+      outputPath: 'sdui_schema.json',
+      flags: FeatureFlags(strictMode: false),
+    ),
+  );
+
+  // Handle the result.
+  result.fold(
+    onSuccess: (schema) {
+      print('Schema version: ${schema.schemaVersion}');
+      print('Components found: ${schema.components.length}');
+
+      // Emit as JSON.
+      final emitter = JsonEmitter();
+      final json = emitter.emit(schema);
+      print(json);
+    },
+    onError: (errors) {
+      print('Conversion failed:');
+      for (final error in errors) {
+        print('  $error');
+      }
+    },
+  );
 }
