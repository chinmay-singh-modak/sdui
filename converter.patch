+/// The result of comparing two [SduiSchema] versions.
+///
+/// Contains categorised lists of [breaking] and [nonBreaking] changes.
+/// Use [hasBreakingChanges] to quickly check whether consumers may be
+/// affected.
 class SchemaDiff {
+  /// Changes that may break existing consumers (e.g. prop removed, type
+  /// changed, required prop added).
   final List<BreakingChange> breaking;
+
+  /// Changes that are safe for existing consumers (e.g. new optional prop,
+  /// new component added).
   final List<NonBreakingChange> nonBreaking;
 
+  /// Creates a diff result.
   const SchemaDiff({
     required this.breaking,
     required this.nonBreaking,
   });
 
+  /// `true` when at least one breaking change was detected.
   bool get hasBreakingChanges => breaking.isNotEmpty;
+
+  /// `true` when any change (breaking or non-breaking) was detected.
   bool get hasChanges => breaking.isNotEmpty || nonBreaking.isNotEmpty;
 
+  /// An empty diff representing no changes between two schemas.
   static const SchemaDiff empty = SchemaDiff(breaking: [], nonBreaking: []);
 }
 
+/// A schema change that may break existing consumers.
 class BreakingChange {
+  /// Human-readable description of the breaking change.
   final String description;
 
+  /// Creates a breaking change entry.
   const BreakingChange(this.description);
 
   @override
   String toString() => description;
 }
 
+/// A schema change that is safe for existing consumers.
 class NonBreakingChange {
+  /// Human-readable description of the non-breaking change.
   final String description;
 
+  /// Creates a non-breaking change entry.
   const NonBreakingChange(this.description);
 
   @override
