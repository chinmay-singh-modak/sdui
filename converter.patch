+/// Converts annotated Flutter widgets into SDUI (Server-Driven UI) JSON
+/// schemas.
+///
+/// The converter scans a Flutter project for classes annotated with
+/// `@SduiComponent`, parses their props and actions via the Dart analyzer,
+/// and emits a single JSON schema file describing every component.
+///
+/// ## Quick start
+///
+/// ```dart
+/// import 'package:flutter_sdui_converter/flutter_sdui_converter.dart';
+///
+/// final result = await SduiConverter.convert(projectPath: '.');
+/// result.fold(
+///   onSuccess: (schema) => print(JsonEmitter().emit(schema)),
+///   onError: (errors) => errors.forEach(print),
+/// );
+/// ```
+///
+/// See [SduiConverter.convert] for the full programmatic API and [SduiConfig]
+/// for configuration options.
 library;
 
 export 'src/config/sdui_config.dart';
