{
  "screen": "home",
  "version": 1,
  "cache_ttl": 300,
  "theme": {
    "primary": "#6C63FF",
    "background": "#FFFFFF",
    "text": "#1A1A2E"
  },
  "body": {
    "type": "scroll",
    "children": [
      {
        "type": "image",
        "props": {
          "url": "https://cdn.app.com/banner.png",
          "aspect_ratio": 1.78,
          "corner_radius": 12
        }
      },
      {
        "type": "padding",
        "props": { "all": 16 },
        "children": [
          {
            "type": "column",
            "props": { "spacing": 12 },
            "children": [
              {
                "type": "text",
                "props": {
                  "content": "Welcome back, John!",
                  "style": "heading",
                  "color": "#1A1A2E"
                }
              },
              {
                "type": "text",
                "props": {
                  "content": "Here's what's new today.",
                  "style": "caption",
                  "color": "#9A9A9A"
                }
              },
              {
                "type": "row",
                "props": { "spacing": 8 },
                "children": [
                  {
                    "type": "button",
                    "props": {
                      "label": "Shop Now",
                      "variant": "primary",
                      "full_width": true
                    },
                    "action": {
                      "type": "navigate",
                      "payload": { "route": "/shop" }
                    }
                  },
                  {
                    "type": "button",
                    "props": {
                      "label": "Explore",
                      "variant": "outline",
                      "full_width": true
                    },
                    "action": {
                      "type": "navigate",
                      "payload": { "route": "/explore" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "divider",
        "props": { "color": "#EFEFEF", "thickness": 1 }
      },
      {
        "type": "padding",
        "props": { "horizontal": 16, "vertical": 8 },
        "children": [
          {
            "type": "text",
            "props": {
              "content": "Featured Products",
              "style": "subheading"
            }
          }
        ]
      },
      {
        "type": "list",
        "props": {
          "direction": "horizontal",
          "spacing": 12,
          "padding": { "horizontal": 16 }
        },
        "children": [
          {
            "type": "card",
            "props": {
              "corner_radius": 12,
              "elevation": 2,
              "width": 160
            },
            "action": {
              "type": "navigate",
              "payload": { "route": "/product/1" }
            },
            "children": [
              {
                "type": "column",
                "props": { "spacing": 8 },
                "children": [
                  {
                    "type": "image",
                    "props": {
                      "url": "https://cdn.app.com/product1.png",
                      "aspect_ratio": 1,
                      "corner_radius": 8
                    }
                  },
                  {
                    "type": "padding",
                    "props": { "all": 8 },
                    "children": [
                      {
                        "type": "column",
                        "props": { "spacing": 4 },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "content": "Running Shoes",
                              "style": "body",
                              "max_lines": 2
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "content": "$99.00",
                              "style": "caption",
                              "color": "#6C63FF"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "card",
            "props": {
              "corner_radius": 12,
              "elevation": 2,
              "width": 160
            },
            "action": {
              "type": "navigate",
              "payload": { "route": "/product/2" }
            },
            "children": [
              {
                "type": "column",
                "props": { "spacing": 8 },
                "children": [
                  {
                    "type": "image",
                    "props": {
                      "url": "https://cdn.app.com/product2.png",
                      "aspect_ratio": 1,
                      "corner_radius": 8
                    }
                  },
                  {
                    "type": "padding",
                    "props": { "all": 8 },
                    "children": [
                      {
                        "type": "column",
                        "props": { "spacing": 4 },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "content": "Wireless Headphones",
                              "style": "body",
                              "max_lines": 2
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "content": "$149.00",
                              "style": "caption",
                              "color": "#6C63FF"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "padding",
        "props": { "all": 16 },
        "children": [
          {
            "type": "card",
            "props": {
              "corner_radius": 16,
              "background": "#6C63FF"
            },
            "action": {
              "type": "api_call",
              "payload": {
                "endpoint": "/promo/claim",
                "method": "POST",
                "body": { "promo_id": "SUMMER24" }
              }
            },
            "children": [
              {
                "type": "padding",
                "props": { "all": 20 },
                "children": [
                  {
                    "type": "row",
                    "props": {
                      "spacing": 12,
                      "alignment": "center"
                    },
                    "children": [
                      {
                        "type": "icon",
                        "props": {
                          "name": "local_offer",
                          "size": 32,
                          "color": "#FFFFFF"
                        }
                      },
                      {
                        "type": "column",
                        "props": { "spacing": 4 },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "content": "Summer Sale",
                              "style": "subheading",
                              "color": "#FFFFFF"
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "content": "Get 20% off your next order",
                              "style": "caption",
                              "color": "#FFFFFFAA"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}