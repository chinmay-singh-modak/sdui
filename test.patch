+import 'package:flutter/material.dart';
+import 'package:flutter_sdui_test/flutter_sdui_test.dart';
+
+/// Example: golden-testing a native widget against its SDUI equivalent.
+///
+/// Run with:
+/// ```bash
+/// flutter test --update-goldens   # generate goldens
+/// flutter test                    # compare against saved goldens
+/// ```
+void main() {
+  // Compare a native widget against the SDUI-rendered version from a JSON
+  // schema. This registers one testWidgets case per device.
+  sduiGoldenTest(
+    'example button',
+    nativeWidget: const Center(
+      child: ElevatedButton(
+        onPressed: null,
+        child: Text('Tap me'),
+      ),
+    ),
+    schema: {
+      'screen': 'example',
+      'body': {
+        'type': 'button',
+        'props': {'label': 'Tap me'},
+      },
+    },
+    devices: [SduiDevices.phone, SduiDevices.small],
+    threshold: 0.02,
+  );
+}
